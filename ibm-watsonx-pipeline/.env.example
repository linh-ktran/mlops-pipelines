# IBM Cloud / watsonx credentials
WATSONX_API_KEY=your-ibm-cloud-api-key
WATSONX_PROJECT_ID=your-watsonx-project-id
WATSONX_URL=https://eu-de.ml.cloud.ibm.com
WATSONX_SPACE_ID=your-deployment-space-id

# IBM Cloud Object Storage
COS_ENDPOINT=https://s3.eu-de.cloud-object-storage.appdomain.cloud
COS_API_KEY=your-cos-api-key
COS_INSTANCE_CRN=crn:v1:bluemix:public:cloud-object-storage:global:...
COS_BUCKET=watsonx-pipeline-bucket

# Pipeline settings
PIPELINE_MODE=full
RETRAINING_DAY=6

