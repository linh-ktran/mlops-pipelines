# IBM Cloud Object Storage credentials
COS_ENDPOINT=https://s3.eu-de.cloud-object-storage.appdomain.cloud
COS_API_KEY=your-ibm-cloud-api-key-here
COS_INSTANCE_CRN=crn:v1:bluemix:public:cloud-object-storage:global:a/xxxx:yyyy::
COS_BUCKET=energy-forecast-bucket

# Pipeline configuration
PIPELINE_MODE=full
RETRAINING_DAY=6

# Optional: MLflow tracking (if you want experiment tracking)
# MLFLOW_TRACKING_URI=http://localhost:5000

